# LLM Provider - 'openai', 'openrouter', or 'anthropic'
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# WhatsApp - no tokens needed, uses QR code auth
WHATSAPP_ENABLED=false

# Voice
VOICE_ENABLED=false
VOICE_LANG=en

# Channels to enable (comma-separated): terminal,telegram,discord,slack,whatsapp
ENABLED_CHANNELS=terminal

# Agent name
AGENT_NAME=Mr. Robot

# Scheduled tasks (cron format)
DAILY_SUMMARY_CRON=0 9 * * *
DAILY_SUMMARY_ENABLED=false

# Health Check Server
HEALTH_ENABLED=true
HEALTH_PORT=3000

# MCP Server (Model Context Protocol)
MCP_SERVER_ENABLED=false
MCP_SERVER_PORT=3001
MCP_SERVER_AUTH_TOKEN=your-secret-token-here

# API Server (Web Dashboard)
API_SERVER_ENABLED=false
API_SERVER_PORT=3002
# Bind address: 127.0.0.1 (localhost only, default) or 0.0.0.0 (all interfaces)
API_SERVER_HOST=127.0.0.1
# Bearer token required in Authorization header for all API routes (leave blank to disable auth in dev)
API_SERVER_TOKEN=
# Allowed CORS origin (e.g. https://your-domain.com). Leave blank for same-origin only.
API_SERVER_CORS_ORIGIN=
