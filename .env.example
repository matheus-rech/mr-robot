# LLM Provider - 'openai' or 'openrouter'
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# WhatsApp - no tokens needed, uses QR code auth
WHATSAPP_ENABLED=false

# Voice
VOICE_ENABLED=false
VOICE_LANG=en

# Channels to enable (comma-separated): terminal,telegram,discord,slack,whatsapp
ENABLED_CHANNELS=terminal

# Agent name
AGENT_NAME=Mr. Robot

# Scheduled tasks (cron format)
DAILY_SUMMARY_CRON=0 9 * * *
DAILY_SUMMARY_ENABLED=false
